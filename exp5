#include <stdio.h>

int main()
{
    int n, bt[10], pr[10], wt[10], tat[10];
    int temp;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++)
    {
        printf("Burst Time of P%d: ", i + 1);
        scanf("%d", &bt[i]);

        printf("Priority of P%d: ", i + 1);
        scanf("%d", &pr[i]);
    }

    for(int i = 0; i < n - 1; i++)
    {
        for(int j = i + 1; j < n; j++)
        {
            if(pr[i] > pr[j])
            {
                temp = pr[i];
                pr[i] = pr[j];
                pr[j] = temp;

                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;
            }
        }
    }

    wt[0] = 0;

    for(int i = 1; i < n; i++)
        wt[i] = wt[i - 1] + bt[i - 1];

    printf("\nPriority\tBT\tWT\tTAT\n");

    for(int i = 0; i < n; i++)
    {
        tat[i] = wt[i] + bt[i];
        printf("%d\t\t%d\t%d\t%d\n", pr[i], bt[i], wt[i], tat[i]);
    }

    return 0;
}
